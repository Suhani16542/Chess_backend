{
  "name": "chess-academy-backend",
  "version": "1.0.0",
  "description": "Production-ready backend for Chess Academy — Node.js, Express, TypeScript, MongoDB, Resend",
  "main": "dist/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "npm run build && node dist/server.js",
    "dev:ts": "ts-node-dev --respawn --transpile-only --exit-child src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "chess",
    "academy",
    "backend",
    "express",
    "typescript",
    "mongodb"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "mongoose": "^8.15.0",
    "morgan": "^1.11.0",
    "nodemailer": "^6.9.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "4.17.x",
    "@types/morgan": "^1.9.10",
    "@types/nodemailer": "^8.0.1",
    "@types/node": "^26.1.1",
    "rimraf": "^6.1.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "5.8.3"
  }
}
